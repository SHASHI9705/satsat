generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String   @unique
  password String?
  phone    String? // Made optional
  address  String?
  googleId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestTable {
  id   Int    @id @default(autoincrement())
  name String
}


