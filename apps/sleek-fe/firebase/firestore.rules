rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isParticipant() {
      return isSignedIn() && request.auth.uid in resource.data.participants;
    }

    function isParticipantCreate() {
      return isSignedIn() && request.auth.uid in request.resource.data.participants;
    }

    // Chats: one-to-one product chats
    match /chats/{chatId} {
      allow read: if isParticipant();
      allow create: if isParticipantCreate()
        && request.resource.data.participants.size() == 2
        && request.resource.data.productId is string
        && request.resource.data.buyerId is string
        && request.resource.data.sellerId is string;
      allow update: if isParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant();
        allow create: if isParticipantCreate()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string;
        allow update: if isParticipant();
        allow delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.type == 'chat';
      allow read: if isSignedIn() && request.auth.uid == resource.data.toUserId;
      allow update: if isSignedIn() && request.auth.uid == resource.data.toUserId;
      allow delete: if false;
    }

    // ensure users store fcm tokens in their user doc under `fcmTokens`
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
